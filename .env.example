# Payment Gateway Configuration
# 1. Database URL for PostgreSQL (e.g. Supabase, Render, Railway, Local)
DATABASE_URL="postgresql://user:password@host:port/database"

# 2. Your UPI ID where payments should be sent
UPI_ID="your_upi_id@bank"

# 2. Name displayed to users when paying
MERCHANT_NAME="Your Business Name"

# 3. Your Gmail address used to receive payment alerts (FamPay, PhonePe, Paytm, Bank emails)
GMAIL_USER="your-email@gmail.com"

# 4. Your Gmail App Password (16-character code from Google Account -> Security -> 2-Step Verification -> App passwords)
# DO NOT use your normal Gmail password!
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# 5. Telegram Bot Token (Get this from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# 6. Allowed Telegram User ID (Get your ID from @userinfobot to restrict access to yourself)
ALLOWED_TELEGRAM_USER_ID="123456789"
